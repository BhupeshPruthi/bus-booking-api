# Copy to /etc/nginx/sites-available/ and symlink to sites-enabled.
# Replace api.example.com and adjust upstream port if not 8080.
# After testing: certbot --nginx -d api.example.com

upstream bus_booking_api {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 80;
    server_name api.example.com;

    location / {
        proxy_pass http://bus_booking_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
