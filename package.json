{
  "name": "bus-booking-api",
  "version": "1.0.0",
  "description": "Bus Booking Backend API with seat reservation and payment screenshot upload",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make",
    "seed": "knex seed:run",
    "db:dump-data": "node scripts/dump-db-data.js",
    "api:list": "node scripts/list-api-routes.js",
    "start:prod": "NODE_ENV=production node src/app.js"
  },
  "keywords": [
    "node",
    "express",
    "api",
    "bus-booking",
    "postgresql"
  ],
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
