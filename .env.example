# Server Configuration
PORT=8080
# Listen on all interfaces (default 0.0.0.0)
HOST=0.0.0.0
NODE_ENV=development

# Reverse proxy (nginx): set TRUST_PROXY=1 in production so rate limits use real client IPs
# TRUST_PROXY=1
# Optional: number of hops if behind multiple proxies (default 1)
# TRUST_PROXY_HOPS=1

# CORS: comma-separated origins (no spaces). Use your API domain and any web clients.
# Example: https://api.example.com,https://app.example.com
ALLOWED_ORIGINS=*

# Database — use ONE of:
# (A) Single URL (recommended on VPS / managed PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/bus_booking
# (B) Or discrete variables (DATABASE_URL takes precedence if set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bus_booking
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Configuration (required when NODE_ENV=production)
# Use a long random string on the server. Generate: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# Optional: read secret from a file instead (Docker secrets, Kubernetes)
# JWT_SECRET_FILE=/run/secrets/jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google Sign-In — MUST be OAuth "Web application" client ID (Google Cloud → Credentials → Create).
# Same value as MyBus local.properties → google.web.client.id
# Do NOT use only the Android client ID here; create a separate Web client in the same project.
GOOGLE_CLIENT_ID=

# Superuser (admin UI + privileges): match legacy mobile and/or Google account email
SUPER_USER_MOBILE=
SUPER_USER_EMAIL=

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
